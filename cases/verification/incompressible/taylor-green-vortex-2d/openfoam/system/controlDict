FoamFile { version 2.0; format ascii; class dictionary; object controlDict; }
application icoFoam;
startFrom startTime; startTime 0; stopAt endTime; endTime 0.5;
deltaT 0.001; writeControl timeStep; writeInterval 100;
functions {
    sampleDict {
        type sets;
        libs ("libsampling.so");
        writeControl outputTime;
        interpolationScheme cellPoint;
        setFormat csv;
        fields (U p);
        sets (
            line_y0 {
                type lineUniform; axis x;
                start (0 3.14159 0.05); end (6.28318 3.14159 0.05); nPoints 64;
            }
        );
    }
}
